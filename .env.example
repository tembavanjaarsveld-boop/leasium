# App
APP_NAME=Leasium
APP_ENV=local
API_HOST=0.0.0.0
API_PORT=8000
PUBLIC_API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_REGEX=
LEASIUM_ACCESS_PASSWORD=

# Database
DATABASE_URL=postgresql+psycopg://stewart:stewart@localhost:5432/stewart
TEST_DATABASE_URL=postgresql+psycopg://stewart:stewart@localhost:5432/stewart_test

# Redis
REDIS_URL=redis://localhost:6379/0

# Object storage (MinIO locally, R2-compatible later)
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY_ID=stewart
S3_SECRET_ACCESS_KEY=stewart-password
S3_BUCKET=stewart-local
S3_REGION=auto

# Auth
AUTH_MODE=dev
DEV_USER_ID=00000000-0000-7000-8000-000000000001
DEV_USER_EMAIL=temba@example.com
DEV_USER_NAME=Temba van Jaarsveld
DEV_ORGANISATION_ID=00000000-0000-7000-8000-000000000100
CLERK_SECRET_KEY=
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# Optional only when Clerk Dashboard is configured for the exact proxy URL.
# Production should prefer a Clerk frontend API host such as clerk.leasium.ai.
NEXT_PUBLIC_CLERK_PROXY_URL=
OPERATOR_INVITE_TTL_HOURS=72
OPERATOR_INVITE_EMAIL_ENABLED=true
OPERATOR_INVITE_TEMPLATE_KEY=operator_invite
OPERATOR_INVITE_TEMPLATE_VERSION=v1

# Integrations reserved for later phases
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# Used by /api/v1/public-enrichment/property-images/preview to query Google Images
# Generate a key at https://serpapi.com/manage-api-key. Without it, the endpoint
# returns 503 and no records are mutated.
SERPAPI_API_KEY=
# Days without a payment reconciliation preview/apply before /xero/status
# flags Xero-linked open invoices as stale. Operator-configurable.
XERO_RECONCILIATION_STALE_AFTER_DAYS=7
LEASE_INTAKE_MAX_BYTES=15000000
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=
XERO_REDIRECT_URI=http://localhost:8000/api/v1/xero/oauth/callback
XERO_STATE_SECRET=
XERO_TOKEN_ENCRYPTION_KEY=
XERO_AUTHORIZE_URL=https://login.xero.com/identity/connect/authorize
XERO_TOKEN_URL=https://identity.xero.com/connect/token
XERO_CONNECTIONS_URL=https://api.xero.com/connections
XERO_API_BASE_URL=https://api.xero.com/api.xro/2.0
XERO_DEFAULT_SCOPES=offline_access accounting.contacts.read accounting.settings.read accounting.invoices
XERO_HTTP_TIMEOUT_SECONDS=15

# Twilio communications
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_FROM_NAME=Leasium
SENDGRID_MAIL_SEND_URL=https://api.sendgrid.com/v3/mail/send
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_FROM_PHONE=
TWILIO_API_BASE_URL=https://api.twilio.com
COMMUNICATIONS_WEBHOOK_SECRET=
COMMUNICATIONS_TIMEOUT_SECONDS=10
TENANT_ONBOARDING_EMAIL_ENABLED=true
TENANT_ONBOARDING_SMS_ENABLED=true

SLACK_WEBHOOK_URL=
